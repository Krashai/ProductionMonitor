# Skopiuj do .env i ustaw własne wartości przed pierwszym uruchomieniem:
#   cp .env.example .env

# Token współdzielony między gateway a dashboardem dla /api/notify.
NOTIFY_TOKEN=change-me-in-production

# Hasło dostępu do /planning (logowanie operatorów/planistów).
# Zmiana wymaga restartu: docker compose up -d dashboard-app
PLANNING_PASSWORD=zmienhaslo

# Sekret podpisujący HMAC-SHA256 cookie sesji planowania.
# Wygeneruj: openssl rand -hex 32
# Min. 32 znaki. Zmiana unieważnia wszystkie aktywne sesje.
PLANNING_SESSION_SECRET=wygeneruj_przez_openssl_rand_hex_32
